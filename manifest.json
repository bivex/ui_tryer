{
  "manifest_version": 3,
  "name": "Pixel Police - Design Perfection Enforcer",
  "version": "1.0.0",
  "description": "The pixel-perfect police force that catches UI crimes! Validates spacing, sizing, colors, and responsive design against your design system.",
  "author": "UI Inspector Team",

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "action": {
    "default_popup": "ui/popup/popup.html",
    "default_title": "UI Inspector",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "content/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "match_about_blank": false
    }
  ],

  "options_page": "ui/options/options.html",

  "commands": {
    "toggle-inspect": {
      "suggested_key": {
        "default": "Ctrl+Shift+I",
        "mac": "Command+Shift+I"
      },
      "description": "Переключить режим инспекции элементов"
    },
    "generate-report": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Сгенерировать отчет по странице"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["content/*"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "minimum_chrome_version": "88"
}
